{
  "manifest_version": 3,
  "name": "VML AEM 360 Tool",
  "version": "1.0",
  "description": "Herramienta para inyectar estructuras de assets en AEM con renombrado automático.",
  "permissions": [
    "activeTab"
  ],
  "host_permissions": [
    "https://*.adobeaemcloud.com/*"
  ],
  "action": {
    "default_popup": "core/popup.html",
    "default_icon": "assets/logo-vml.png"
  },
  "icons": {
    "128": "assets/logo-vml.png"
  },
  "content_scripts": [
    {
      "matches": [
        "https://*.adobeaemcloud.com/*"
      ],
      "js": [
        "modules/asset-injector/content-asset-renamer.js",
        "modules/asset-injector/content-asset-injector.js"
      ],
      "css": [
        "core/content.css"
      ],
      "all_frames": false
    }
  ]
}
